{
  "name": "grreat",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:worker": "wrangler dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "astro check",
    "guardrails": "bash scripts/guardrails.sh",
    "check": "astro check && vitest run && npm run guardrails",
    "db:migrate:local": "wrangler d1 migrations apply grreat-waitlist --local",
    "db:migrate:remote": "wrangler d1 migrations apply grreat-waitlist --remote",
    "deploy": "astro build && wrangler deploy -c dist/server/wrangler.json"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "astro": "^7.0.9"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
