---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  theme?: 'light' | 'dark';
}

const {
  title = 'GRREAT — Project operating system for humans and AI agents',
  description = 'Goals, Research, Roadmaps, Execution, Analysis & Time. An operating system for humans and AI agents.',
  ogImage = '/og-image.jpg',
  theme,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f0ede4" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Icons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Fonts (self-hosted; @font-face lives in the inlined global.css) -->
    <link
      rel="preload"
      href="/fonts/dm-serif-display-latin-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="shell">
      <slot />
    </div>
  </body>
</html>

<style>
  /* Skip link — hidden until keyboard focus */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 24px;
    z-index: 100;
    padding: 10px 16px;
    background: var(--surface-inverse);
    /* Legacy text is literally `--paper`, not the paper-light `--text-inverse`
       Button uses — --surface-page points at the same primitive, keeping this
       off the raw color while matching the exact legacy pixel (see Masthead
       .kicker-chip for the same substitution). */
    color: var(--surface-page);
    font: 0.8125rem var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
  }

  .skip-link:focus {
    top: 8px;
  }

  /* Layout shell — single-column for signup, no sidebar */
  .shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
</style>
