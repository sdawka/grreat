---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  theme?: 'light' | 'dark';
}

const {
  title = 'GRREAT — Project operating system for humans and AI agents',
  description = 'Goals, Research, Roadmap, Execution, Analysis & Time. An operating system for humans and AI agents.',
  ogImage = '/og-image.jpg',
  theme,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f0ede4" />
    <meta name="generator" content={Astro.generator} />

    <!-- Theme: set data-theme before paint (no flash). Saved choice wins,
         else the OS preference. Toggle (ThemeToggle) persists to localStorage. -->
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('theme');
          const theme = saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (_) {}
      })();
    </script>

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Icons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Fonts (self-hosted; @font-face lives in the inlined global.css) -->
    <link
      rel="preload"
      href="/fonts/dm-serif-display-latin-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="shell">
      <slot />
    </div>
  </body>
</html>

<style>
  /* Skip link — hidden until keyboard focus */
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-6);
    z-index: 100;
    padding: var(--space-legacy-10) var(--space-4);
    background: var(--surface-inverse);
    color: var(--text-on-inverse);
    font-family: var(--mono);
    font-size: var(--text-3);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps-1);
    text-decoration: none;
  }

  .skip-link:focus {
    top: var(--space-2);
  }

  /* Layout shell — single-column for signup, no sidebar */
  .shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
</style>
