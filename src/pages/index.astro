---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/patterns/Topbar.astro';
import Masthead from '../components/landing/Masthead.astro';
import BucketExplainer from '../components/landing/BucketExplainer.astro';
import FeedbackLoop from '../components/landing/FeedbackLoop.astro';
import WorkingSession from '../components/landing/WorkingSession.astro';
import Principles from '../components/landing/Principles.astro';
import SignupForm from '../components/landing/SignupForm.astro';
import SecondaryCTA from '../components/landing/SecondaryCTA.astro';
import Footer from '../components/patterns/Footer.astro';
---

<BaseLayout
  title="GRREAT — Project operating system for humans and AI agents"
  description="Goals, Research, Roadmaps, Execution, Analysis & Time. A cyclical feedback operating system for humans and AI agents. Join the waitlist for early access."
>
  <Topbar />

  <main id="main">
    <Masthead>
      <SignupForm slot="form" />
    </Masthead>

    <BucketExplainer />

    <FeedbackLoop />

    <WorkingSession />

    <Principles />

    <SecondaryCTA>
      <SignupForm slot="form" />
    </SecondaryCTA>
  </main>

  <Footer />
</BaseLayout>
