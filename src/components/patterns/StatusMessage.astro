---
// aria-live region for async form feedback. `data-state` drives color (never
// a class toggle); forms point at this element's id via aria-describedby
// instead of relying on DOM position (nextElementSibling).
export interface Props {
  state: 'idle' | 'success' | 'error' | 'warning';
  id: string;
  class?: string;
}

const { state, id, class: className, ...rest } = Astro.props;
---

<div
  id={id}
  class:list={['status-message', className]}
  data-state={state}
  role="status"
  aria-live="polite"
  {...rest}
>
  <slot />
</div>

<style>
  .status-message {
    margin-block-start: var(--space-3);
    font-family: var(--mono);
    font-size: var(--text-3);
    line-height: var(--leading-legacy-status);
    color: var(--text-strong);
  }

  .status-message[data-state='success'] { color: var(--feedback-success); }
  .status-message[data-state='error']   { color: var(--feedback-error); }
  .status-message[data-state='warning'] { color: var(--feedback-warning); }
</style>
