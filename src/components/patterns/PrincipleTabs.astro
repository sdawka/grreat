---
import type { CorePrinciple } from '../../content/corePrinciples';

// CSS-only single-select tabs: one radio per principle, one shared explanation
// panel below. No JS — the :checked state drives which panel shows, so the page
// stays fully prerendered. The show/hide rules are keyed to nth-of-type, so they
// assume a fixed three-item list (see the block at the end of <style>); adding a
// fourth principle means adding a fourth nth-of-type pair there.
export interface Props {
  items: CorePrinciple[];
  class?: string;
}

const { items, class: className, ...rest } = Astro.props;
---

<fieldset class:list={['ptabs', className]} {...rest}>
  <legend class="ptabs-legend">Principles</legend>

  {items.map((p, i) => (
    <Fragment>
      <input
        class="ptabs-radio"
        type="radio"
        name="principle"
        id={`principle-${i}`}
        checked={i === 0}
      />
      <label class="ptabs-tab" for={`principle-${i}`}>{p.name}</label>
    </Fragment>
  ))}

  <div class="ptabs-panels">
    {items.map((p) => (
      <div class="ptabs-panel">
        <strong class="ptabs-lead">{p.lead}</strong>
        <p class="ptabs-note">{p.note}</p>
      </div>
    ))}
  </div>
</fieldset>

<style>
  .ptabs {
    /* fieldset reset, then a wrapping flex row so the labels sit inline and the
       panel wraps to its own full-width line below them */
    border: 0;
    margin: 0;
    padding: 0;
    min-inline-size: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .ptabs-legend {
    /* visually hidden: the Section <h2> already names this region; the legend
       exists only to give the radio group its own accessible name */
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  .ptabs-radio {
    /* hidden but still focusable, so the group keeps native arrow-key navigation */
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .ptabs-tab {
    font-family: var(--mono);
    font-size: var(--text-2);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps-1);
    padding: var(--space-2) var(--space-4);
    border: var(--border-1) solid var(--border-strong);
    color: var(--text-strong);
    cursor: pointer;
    user-select: none;
    transition: background var(--duration-fast), color var(--duration-fast);
  }

  @media (hover: hover) {
    .ptabs-tab:hover {
      background: var(--surface-accent);
      color: var(--text-on-accent);
    }
  }

  /* active tab — filled ink chip, mirroring the hero kicker-chip */
  .ptabs-radio:checked + .ptabs-tab {
    background: var(--surface-inverse);
    color: var(--text-on-inverse);
  }

  /* surface the hidden radio's keyboard focus on its visible label */
  .ptabs-radio:focus-visible + .ptabs-tab {
    outline: var(--border-2) solid var(--focus-ring);
    outline-offset: var(--space-1);
  }

  .ptabs-panels {
    flex-basis: 100%;
    margin-block-start: var(--space-5);
    border: var(--border-1) solid var(--border-strong);
    padding: var(--space-6) var(--gutter-legacy-min);
  }

  .ptabs-panel {
    display: none;
  }

  .ptabs-lead {
    display: block;
    font-family: var(--serif);
    font-weight: 400;
    font-size: var(--text-5);
    line-height: var(--leading-snug);
    margin-block-end: var(--space-3);
  }

  .ptabs-note {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--text-3);
    line-height: var(--leading-relaxed);
    color: var(--text-muted);
    max-inline-size: var(--measure);
  }

  /* Reveal only the panel matching the checked radio. Keyed to a fixed 3-item
     list — see the component header note before changing the principle count. */
  .ptabs-radio:nth-of-type(1):checked ~ .ptabs-panels .ptabs-panel:nth-of-type(1),
  .ptabs-radio:nth-of-type(2):checked ~ .ptabs-panels .ptabs-panel:nth-of-type(2),
  .ptabs-radio:nth-of-type(3):checked ~ .ptabs-panels .ptabs-panel:nth-of-type(3) {
    display: block;
  }
</style>
