---
import Prose from './primitives/Prose.astro';

// Second signup CTA and compact privacy copy
---

<hr class="section-rule" aria-hidden="true" />

<section class="cta-section" aria-labelledby="cta-title">
  <div class="section-header">
    <span class="section-number">05 /</span>
    <h2 id="cta-title" class="section-title">Join the working edition</h2>
  </div>

  <Prose class="intro" measure={false}>
    Get public-edition launch notes, early product access, and system updates as GRREAT moves from a working method into a tool you can run with your AI agent.
  </Prose>

  <Prose class="closing" measure={false}>
    You're reading the working edition — join to get the public edition when it ships.
  </Prose>

  <slot name="form" />
</section>

<style>
  /* Legacy exact width/spacing, pending Step 3's Section `intro` slot. */
  .intro {
    max-inline-size: 37.5rem; /* 600px */
    margin-block-end: var(--space-3);
  }

  .closing {
    max-inline-size: 37.5rem; /* 600px */
    margin-block-end: 1.75rem; /* 28px — no exact space-token match */
  }
</style>

