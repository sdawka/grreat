---
import Section from '../layout/Section.astro';
import Prose from '../primitives/Prose.astro';
import Stack from '../layout/Stack.astro';
import HighlightCard from '../patterns/HighlightCard.astro';

// "How a working session feels" — NOW card, owner split (you vs Hermes), and feedback update
---

<Section title="How a working session feels" id="session">
  <Prose slot="intro" measure={false}>
    Every session starts with one card: your current next action. No open loops, no context switching.
    Every item has an owner — either you or your AI agent — and ownership is explicit.
  </Prose>

  <Stack gap={5}>
    <HighlightCard index="01" label="Primary next action" owner="You" aria-label="Session view example">
      Ship the MVP landing page
    </HighlightCard>

    <HighlightCard index="02" label="Primary next action" owner="AI agent" aria-label="AI agent session view">
      Draft this week's newsletter &amp; flag gaps
    </HighlightCard>
  </Stack>

  <p class="caption">
    ↔ When a card is done, the owner signals completion. Analysis runs, feedback loops fire,
    and the next primary action surfaces. No orphaned projects.
  </p>
</Section>

<style>
  .caption {
    /* legacy's inline style only set margin-top: 20px, leaving the UA <p> default
       margin-bottom (1em @ this element's 12px font-size = 12px) in place. */
    margin-block: var(--space-5) var(--space-3);
    margin-inline: 0;
    font-family: var(--mono);
    font-size: var(--text-2);
    line-height: var(--leading-normal);
    color: var(--text-muted);
  }
</style>
