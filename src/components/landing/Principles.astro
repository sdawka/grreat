---
import Section from '../layout/Section.astro';
import Prose from '../primitives/Prose.astro';
import AnnotatedList from '../patterns/AnnotatedList.astro';
import { principles } from '../../content/principles';

// Principles: exactly one next action, explicit owner, WIP max 5, queue max 3,
// no orphaned projects, proposal-only structural changes
const items = principles.map((p, i) => ({ ...p, marker: String(i + 1).padStart(2, '0') }));
---

<Section title="Principles">
  <Prose slot="intro" measure={false}>
    The system enforces a small set of hard constraints. These are not suggestions — they are
    invariants that keep the operating system from degrading.
  </Prose>

  <AnnotatedList items={items} columns={2} as="ol" />
</Section>
