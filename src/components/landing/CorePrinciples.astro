---
import Section from '../layout/Section.astro';
import Prose from '../primitives/Prose.astro';
import PrincipleTabs from '../patterns/PrincipleTabs.astro';
import { corePrinciples } from '../../content/corePrinciples';

// Principles: cyclical, honest, action — the philosophy the rest of the system
// (feedback loops, constraints) implements. Presented as a select-to-explain tab
// set so one idea reads at a time.
---

<Section title="Principles">
  <Prose slot="intro" measure={false}>
    Three ideas the rest of the system is built to serve. Pick one to read it.
  </Prose>

  <PrincipleTabs items={corePrinciples} />
</Section>
