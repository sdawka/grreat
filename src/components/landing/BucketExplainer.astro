---
import Section from '../layout/Section.astro';
import Prose from '../primitives/Prose.astro';
import UseCaseCarousel from '../patterns/UseCaseCarousel.astro';

// The six buckets are the fixed axis; the use-case carousel is the second axis
// that reflavors every card — same G / R¹ / R² / E / A / T, any goal.
---

<Section title="Six buckets, any goal" id="buckets">
  <Prose slot="intro" measure={false}>
    The six buckets never change — only their flavor does. Pick a goal and watch the
    same G · R¹ · R² · E · A · T retune to it.
  </Prose>

  <UseCaseCarousel />
</Section>
