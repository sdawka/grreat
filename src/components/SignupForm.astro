---
import VisuallyHidden from './primitives/VisuallyHidden.astro';

// Reusable signup form. Each rendered instance initializes independently.
---

<form class="signup-form" data-signup-form novalidate aria-label="Waitlist signup">
  <VisuallyHidden as="div" aria-hidden="true">
    <label>Leave this empty
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </label>
  </VisuallyHidden>

  <div class="field">
    <label>
      <span class="sr-only">Email address</span>
      <input
        type="email"
        name="email"
        placeholder="you@example.com"
        required
        autocomplete="email"
      />
    </label>
  </div>

  <button type="submit">Join waitlist</button>
</form>

<div class="form-message" role="status" aria-live="polite"></div>

<p class="privacy-note">
  No spam. We never share your data. Unsubscribe at any time.
</p>

<script>
  interface SignupResponse {
    success: boolean;
    message?: string;
    error?: string;
  }

  document.querySelectorAll<HTMLFormElement>('[data-signup-form]').forEach((form) => {
    if (form.dataset.initialized === 'true') return;
    form.dataset.initialized = 'true';

    const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]')!;
    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
    const messageEl = form.nextElementSibling as HTMLDivElement;

    function setState(
      state: 'idle' | 'submitting' | 'success' | 'error' | 'config-error',
      message: string,
    ) {
      messageEl.textContent = message;
      messageEl.className = 'form-message';
      if (state !== 'idle' && state !== 'submitting') messageEl.classList.add(state);
      submitBtn.disabled = state === 'submitting';
      emailInput.disabled = state === 'submitting';
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const email = emailInput.value;
      const website = form.querySelector<HTMLInputElement>('input[name="website"]')?.value;

      if (!email || email.trim().length === 0) {
        setState('error', 'Please enter your email address.');
        emailInput.focus();
        return;
      }

      setState('submitting', 'Joining the waitlist…');

      try {
        const response = await fetch('/api/signup', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ email: email.trim(), website }),
        });
        const data: SignupResponse = await response.json();

        if (response.status === 200 && data.success) {
          setState('success', '✓ You are on the list. We’ll be in touch.');
          emailInput.value = '';
        } else if (response.status === 409) {
          setState('success', '✓ You’re already on the list — nothing more to do.');
        } else if (response.status === 503) {
          setState('config-error', data.error || 'Waitlist is not configured yet.');
        } else {
          setState('error', data.error || 'Something went wrong. Please try again.');
        }
      } catch {
        setState('error', 'Network error. Please check your connection and try again.');
      }
    });
  });
</script>
