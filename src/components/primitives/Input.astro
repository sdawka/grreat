---
import type { HTMLAttributes } from 'astro/types';

export interface Props extends Omit<HTMLAttributes<'input'>, 'name'> {
  name: string;
}

const { type = 'text', name, id, placeholder, required = false, class: className, ...rest } = Astro.props;
---

<input
  type={type}
  name={name}
  id={id}
  placeholder={placeholder}
  required={required}
  class:list={['input', className]}
  {...rest}
/>

<style>
  .input {
    display: block;
    width: 100%;
    height: var(--space-9);
    border: var(--border-2) solid var(--border-strong);
    background: var(--surface-raised);
    padding-inline: var(--space-legacy-14);
    font-family: var(--sans);
    font-size: var(--text-legacy-input);
    transition: background var(--duration-fast);
  }

  .input::placeholder {
    color: var(--text-muted);
  }

  /* No custom :focus treatment ⊕: global :focus-visible ring only. */
</style>
